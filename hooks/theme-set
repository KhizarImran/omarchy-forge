#!/bin/bash

# Omarchy theme-set hook
# This is called with the snake-cased name of the theme that has just been set

THEME_NAME="$1"
FORGE_DIR="$HOME/omarchy-forge"

echo "Theme changed to: $THEME_NAME"

# Example: Run custom script when theme changes
# You can add theme-specific configurations here

if [ -f "$FORGE_DIR/scripts/on-theme-change.sh" ]; then
    bash "$FORGE_DIR/scripts/on-theme-change.sh" "$THEME_NAME"
fi
