#!/bin/bash

# Omarchy theme-set hook
# Called by Omarchy with the snake-cased theme name after a theme switch.
# Delegates to on-theme-change.sh which handles Razer RGB keyboard sync.

THEME_NAME="$1"
FORGE_DIR="$HOME/omarchy-forge"

echo "[forge] theme-set hook triggered: $THEME_NAME"

# Sync Razer keyboard RGB to the new theme's accent colour
if [ -f "$FORGE_DIR/scripts/on-theme-change.sh" ]; then
    bash "$FORGE_DIR/scripts/on-theme-change.sh" "$THEME_NAME"
else
    echo "[forge] warning: scripts/on-theme-change.sh not found in $FORGE_DIR"
fi
